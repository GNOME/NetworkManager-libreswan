msgstr "Қашықтағы порт селекторлары (rightprotoport)"

#: ../properties/nm-libreswan-dialog.ui.h:101
msgid "Allowed remote protocols and ports over connection"
msgstr "Байланыс арқылы рұқсат етілген қашықтағы хаттамалар мен порттар"

